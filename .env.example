# Copy to .env and adjust as needed:  cp .env.example .env
#
# Both docker-compose and the app read this file: compose substitutes the *_HOST_PORT vars
# natively, and application.yml imports it via `spring.config.import: optional:file:.env`.
# So `docker compose up -d && mvn spring-boot:run` works with no exported env vars.
#
# If 5432 is already taken on your machine, change the host port below AND the matching DB_URL:
# they must agree or the app won't reach the container.

# --- host port docker-compose publishes on ---
PG_HOST_PORT=5432

# --- what the app connects to (must match the host port above) ---
DB_URL=jdbc:postgresql://localhost:5432/membership
DB_USER=membership
DB_PASSWORD=membership
SERVER_PORT=8080

# --- security ---
# JWT_SECRET has no default in application.yml and the app will not start without it: a signing key
# committed to the repo lets anyone forge an ADMIN token offline. Generate your own for anything
# that isn't a local demo:  openssl rand -base64 48
JWT_SECRET=local-dev-only-hs256-signing-key-change-me-0123456789

# The dev token endpoint mints a JWT for any userId with NO credential, so it satisfies every
# authorization check in the app. It is off by default, and SecurityDefaultsGuard refuses to boot
# with it on unless you also acknowledge that below. Never set either in a deployed environment.
#
# Two switches, not one, on purpose: nobody sets the second while copying a production config.
# (The acknowledgement exists because spring.profiles.active does NOT work from this file —
# profiles are resolved before .env is imported — so a profile alone could not gate it here.)
AUTH_DEV_TOKEN_ENABLED=true
AUTH_DEV_TOKEN_ALLOW_OUTSIDE_DEV=true
# Blank/unset = minting ADMIN tokens is impossible. Set one to exercise admin-only endpoints locally.
ADMIN_BOOTSTRAP_SECRET=local-dev-admin-bootstrap
